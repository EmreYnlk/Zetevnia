# Zetevnia Konfigürasyon
# Bu dosyayı .env olarak kopyalayıp değerleri düzenleyin

# Sunucu Ayarları
ZETEVNIA_HOST=0.0.0.0
ZETEVNIA_PORT=8000
ZETEVNIA_SSL_PORT=8443
ZETEVNIA_DEBUG=true

# CORS
ZETEVNIA_CORS_ALLOW_ALL=true
ZETEVNIA_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting
ZETEVNIA_RATE_LIMIT_MINUTE=30
ZETEVNIA_RATE_LIMIT_HOUR=500

# Güvenlik
ZETEVNIA_MAX_REQUEST_MB=5.0
ZETEVNIA_MAX_FAILED_ATTEMPTS=10
ZETEVNIA_BAN_DURATION_MINUTES=5

# Model
ZETEVNIA_MODEL_PATH=models/rakam_cnn_model.pth
ZETEVNIA_USE_GPU=false

# Logging
ZETEVNIA_LOG_LEVEL=INFO
ZETEVNIA_LOG_FILE=logs/zetevnia.log
